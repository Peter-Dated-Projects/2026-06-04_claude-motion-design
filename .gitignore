# Charm run state is ephemeral and ignored, EXCEPT the durable knowledge base.
# `.charm/*` ignores the run-state children; `!.charm/kb/` re-includes the KB.
.charm/*
!.charm/kb/
!.charm/proposals

# Node / frontend
node_modules/
dist/

# Rust / Tauri build artifacts
src-tauri/target/

# Built MP4-render toolchain archives (uploaded as release assets, not tracked)
dist-toolchain/
