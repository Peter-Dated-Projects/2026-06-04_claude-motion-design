{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClaudeMotion",
  "version": "0.1.0",
  "identifier": "ai.finks.claude-motion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClaudeMotion",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOCUMENT/ClaudeMotion/projects/**/extractions/**",
          "$DOCUMENT/ClaudeMotion/projects/**/assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
